@page "/add"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Add - Bookly</PageTitle>

<div class="add-page">
    <header class="add-header">
        <h2 class="add-title">Add to Collection</h2>
        <p class="add-subtitle">Expand your curated library with a quick calculation test.</p>
    </header>

    <div class="add-form-card card-glass">
        <div class="form-group">
            <label for="numberA" class="form-label">Number A</label>
            <input id="numberA" type="number" class="input-atelier" @bind="NumberA" @bind:event="onchange" />
        </div>

        <div class="form-group">
            <label for="numberB" class="form-label">Number B</label>
            <input id="numberB" type="number" class="input-atelier" @bind="NumberB" @bind:event="onchange" />
        </div>

        <button class="btn-primary-gradient add-submit-btn" @onclick="Calculate" id="calculateBtn">
            <span class="material-symbols-outlined" aria-hidden="true">calculate</span>
            Calculate
        </button>

        @if (IsLoading)
        {
            <div class="state-container" role="status">
                <div class="loading-spinner"></div>
                <p class="state-description">Calculating...</p>
            </div>
        }

        @if (Result is not null)
        {
            <div class="alert-success-atelier" id="result" role="status">
                <span class="material-symbols-outlined" aria-hidden="true">check_circle</span>
                Result: @Result
            </div>
        }

        @if (Error is not null)
        {
            <div class="alert-error-atelier" id="error" role="alert">
                <span class="material-symbols-outlined" aria-hidden="true">error</span>
                @Error
            </div>
        }
    </div>
</div>

@code {
    private int NumberA { get; set; }
    private int NumberB { get; set; }
    private int? Result { get; set; }
    private string? Error { get; set; }
    private bool IsLoading { get; set; }

    private async Task Calculate()
    {
        try
        {
            Error = null;
            Result = null;
            IsLoading = true;
            StateHasChanged();

            var client = HttpClientFactory.CreateClient("BooklyApi");
            var response = await client.GetFromJsonAsync<AddResponse>($"/api/add?a={NumberA}&b={NumberB}");
            Result = response?.Result;
        }
        catch (Exception ex)
        {
            Error = $"Error calling API: {ex.Message}";
            Result = null;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private record AddResponse(int Result);
}
