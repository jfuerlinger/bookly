@page "/book/{Id:int}"
@inject IHttpClientFactory HttpClientFactory
@using System.Net.Http.Json

<PageTitle>@(_book?.Title ?? "Book Details") - Bookly</PageTitle>

<div class="detail-page">
    @if (_isLoading)
    {
        <div class="detail-loading">
            <div class="loading-spinner"></div>
            <p class="state-description">Loading book details...</p>
        </div>
    }
    else if (_errorMessage is not null)
    {
        <div class="detail-error">
            <span class="material-symbols-outlined" aria-hidden="true">error_outline</span>
            <p>@_errorMessage</p>
        </div>
    }
    else if (_book is not null)
    {
        <!-- Hero Section -->
        <section class="detail-hero">
            <div class="detail-hero-bg">
                <div class="detail-hero-gradient"></div>
            </div>
            <div class="detail-hero-content">
                <div class="detail-cover">
                    @{
                        var coverUrl = _book.CoverLargeUrl ?? _book.CoverMediumUrl ?? _book.CoverSmallUrl;
                    }
                    @if (coverUrl is not null)
                    {
                        <img src="@coverUrl" alt="Cover of @_book.Title" class="detail-cover-image" />
                    }
                    else
                    {
                        <div class="detail-cover-placeholder">
                            <span class="material-symbols-outlined" aria-hidden="true">menu_book</span>
                        </div>
                    }
                </div>
                <div class="detail-hero-info">
                    <h1 class="detail-title">@_book.Title</h1>
                    @if (_book.Subtitle is not null)
                    {
                        <p class="detail-subtitle">@_book.Subtitle</p>
                    }
                    @if (_book.Authors.Count > 0)
                    {
                        <p class="detail-author">by @string.Join(", ", _book.Authors)</p>
                    }
                </div>
            </div>
        </section>

        <div class="detail-grid">
            <!-- Left Column -->
            <div class="detail-main">
                <!-- Description -->
                @if (_book.Description is not null)
                {
                    <section class="synopsis-section">
                        <h3 class="synopsis-title">About this book</h3>
                        <p class="synopsis-text">@_book.Description</p>
                    </section>
                }
            </div>

            <!-- Right Column: Metadata -->
            <aside class="detail-sidebar">
                <div class="card-metadata">
                    <h4 class="metadata-heading">Book Details</h4>
                    <dl class="metadata-list">
                        @if (_book.Isbn13 is not null)
                        {
                            <div class="metadata-row">
                                <dt>ISBN-13</dt>
                                <dd class="metadata-mono">@_book.Isbn13</dd>
                            </div>
                        }
                        else if (_book.Isbn10 is not null)
                        {
                            <div class="metadata-row">
                                <dt>ISBN-10</dt>
                                <dd class="metadata-mono">@_book.Isbn10</dd>
                            </div>
                        }
                        @if (_book.PageCount is not null)
                        {
                            <div class="metadata-row">
                                <dt>Pages</dt>
                                <dd>@_book.PageCount</dd>
                            </div>
                        }
                        @if (_book.Publisher is not null)
                        {
                            <div class="metadata-row">
                                <dt>Publisher</dt>
                                <dd>@_book.Publisher</dd>
                            </div>
                        }
                        @if (_book.Language is not null)
                        {
                            <div class="metadata-row">
                                <dt>Language</dt>
                                <dd>@_book.Language</dd>
                            </div>
                        }
                        <div class="metadata-row">
                            <dt>Source</dt>
                            <dd class="text-primary">@_book.MetadataSource</dd>
                        </div>
                        <div class="metadata-row">
                            <dt>Added</dt>
                            <dd>@_book.CreatedAtUtc.ToString("MMM d, yyyy")</dd>
                        </div>
                    </dl>
                </div>
            </aside>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private BookDto? _book;
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("BooklyApi");
            var books = await client.GetFromJsonAsync<List<BookDto>>("/api/library/books") ?? [];
            _book = books.FirstOrDefault(b => b.Id == Id);
            if (_book is null)
            {
                _errorMessage = "Book not found.";
            }
        }
        catch (Exception)
        {
            _errorMessage = "Could not load book details. Please try again later.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private sealed record BookDto
    {
        public int Id { get; init; }
        public string? Isbn10 { get; init; }
        public string? Isbn13 { get; init; }
        public required string NormalizedIsbn { get; init; }
        public required string Title { get; init; }
        public string? Subtitle { get; init; }
        public List<string> Authors { get; init; } = [];
        public string? Publisher { get; init; }
        public string? Language { get; init; }
        public int? PageCount { get; init; }
        public string? Description { get; init; }
        public string? CoverSmallUrl { get; init; }
        public string? CoverMediumUrl { get; init; }
        public string? CoverLargeUrl { get; init; }
        public required string MetadataSource { get; init; }
        public DateTime CreatedAtUtc { get; init; }
        public DateTime UpdatedAtUtc { get; init; }
    }
}
