@page "/"
@inject IHttpClientFactory HttpClientFactory
@using System.Net.Http.Json

<PageTitle>Bookly - Your Curated Library</PageTitle>

<div class="home-page">
    <!-- Hero Section -->
    <section class="hero-section">
        <h2 class="hero-title">
            Your Curated <span class="hero-accent">Collection.</span>
        </h2>
        <p class="hero-subtitle">
            Manage your personal library with the precision of a master curator.
        </p>

        <!-- Search Bar -->
        <div class="search-wrapper">
            <span class="material-symbols-outlined search-icon" aria-hidden="true">search</span>
            <input type="text"
                   class="input-search"
                   placeholder="Search by title, author, or ISBN..."
                   aria-label="Search your library" />
        </div>
    </section>

    <!-- Category Filter Chips -->
    <section class="filter-bar" aria-label="Filter books by category">
        <div class="filter-scroll">
            <button class="chip chip-filter chip-filter-active" aria-pressed="true">All Books</button>
            <button class="chip chip-filter chip-filter-inactive" aria-pressed="false">Currently Reading</button>
            <button class="chip chip-filter chip-filter-inactive" aria-pressed="false">Completed</button>
            <button class="chip chip-filter chip-filter-inactive" aria-pressed="false">Borrowed</button>
            <button class="chip chip-filter chip-filter-inactive" aria-pressed="false">Wishlist</button>
        </div>
    </section>

    <!-- Book Grid -->
    <section class="book-grid" aria-label="Your books">
        @if (_isLoading)
        {
            <div class="loading-state" role="status" aria-live="polite">
                <span class="material-symbols-outlined" aria-hidden="true">hourglass_empty</span>
                <p>Loading your library…</p>
            </div>
        }
        else if (_errorMessage is not null)
        {
            <div class="error-state" role="alert">
                <span class="material-symbols-outlined" aria-hidden="true">error_outline</span>
                <p>@_errorMessage</p>
            </div>
        }
        else if (_books.Count == 0)
        {
            <div class="empty-state">
                <span class="material-symbols-outlined" aria-hidden="true">library_books</span>
                <p>Your library is empty. Scan an ISBN to add your first book!</p>
            </div>
        }
        else
        {
            @foreach (var book in _books)
            {
                var preferredCoverUrl = GetPreferredCoverUrl(book);
                var placeholderClass = GetPlaceholderClass(book.Id);

                <a href="@($"book/{book.Id}")" class="book-card-link">
                    <article class="card-standard book-card">
                        <div class="book-cover">
                            @if (preferredCoverUrl is not null)
                            {
                                <img src="@preferredCoverUrl"
                                     alt="Cover of @book.Title"
                                     class="book-cover-image"
                                     loading="lazy" />
                            }
                            else
                            {
                                <div class="book-cover-placeholder @placeholderClass">
                                    <span class="material-symbols-outlined" aria-hidden="true">auto_stories</span>
                                </div>
                            }
                        </div>
                        <div class="book-info">
                            <h4 class="book-title">@book.Title</h4>
                            @if (book.Authors.Count > 0)
                            {
                                <p class="book-author">@string.Join(", ", book.Authors)</p>
                            }
                        </div>
                    </article>
                </a>
            }
        }
    </section>
</div>

@code {
    private List<BookDto> _books = [];
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("BooklyApi");
            _books = await client.GetFromJsonAsync<List<BookDto>>("/api/library/books") ?? [];
        }
        catch (Exception)
        {
            _errorMessage = "Could not load your library. Please try again later.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private sealed record BookDto
    {
        public int Id { get; init; }
        public string? Isbn10 { get; init; }
        public string? Isbn13 { get; init; }
        public required string NormalizedIsbn { get; init; }
        public required string Title { get; init; }
        public string? Subtitle { get; init; }
        public List<string> Authors { get; init; } = [];
        public string? Publisher { get; init; }
        public string? Language { get; init; }
        public int? PageCount { get; init; }
        public string? Description { get; init; }
        public string? CoverSmallUrl { get; init; }
        public string? CoverMediumUrl { get; init; }
        public string? CoverLargeUrl { get; init; }
        public required string MetadataSource { get; init; }
        public DateTime CreatedAtUtc { get; init; }
        public DateTime UpdatedAtUtc { get; init; }
    }

    private static string GetPlaceholderClass(int id)
    {
        return (id % 4) switch
        {
            0 => "cover-warm",
            1 => "cover-cool",
            2 => "cover-dark",
            3 => "cover-nature",
            _ => "cover-warm"
        };
    }

    private static string? GetPreferredCoverUrl(BookDto book)
    {
        var candidate = book.CoverMediumUrl ?? book.CoverLargeUrl ?? book.CoverSmallUrl;
        if (string.IsNullOrWhiteSpace(candidate))
            return null;

        return candidate.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
            ? $"https://{candidate[7..]}"
            : candidate;
    }
}

